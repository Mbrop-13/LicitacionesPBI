{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/configuracion", "destination": "/config.html" }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 12 * * 1-5"
    }
  ]
}
