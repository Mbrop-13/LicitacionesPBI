# ---- Mercado Público (ChileCompra) ----
# Solicita tu ticket gratis en https://www.mercadopublico.cl/
MERCADOPUBLICO_TICKET=tu-ticket-aqui

# ---- Supabase (opcional) ----
# Si no configuras Supabase, se usa almacenamiento local en /data
# SUPABASE_URL=https://TU-PROYECTO.supabase.co
# SUPABASE_SERVICE_KEY=tu-service-role-key

# ---- Servidor y Cron diario ----
PORT=3000
# 1 = búsqueda automática activada, 0 = solo manual
AUTO_BUSCAR=1
# Cron para ejecutarse todos los días a las 11:00 AM hora de Chile (America/Santiago)
CRON_EXPRESION=0 11 * * *
CRON_TIMEZONE=America/Santiago

# ---- Búsqueda ----
# Días hacia atrás a escanear en cada búsqueda
DIAS_HACIA_ATRAS=5
# Pedir detalle a la API cuando el listado viene sin descripción (1/0)
ENRIQUECER_DETALLE=1

# ---- Notificaciones por Email (Amazon SES / SMTP) ----
EMAIL_ENABLE=1
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=TU_SES_SMTP_USERNAME
SMTP_PASS=TU_SES_SMTP_PASSWORD
EMAIL_FROM="ProgramBI Licitaciones" <licitaciones@tu-dominio-verificado.com>
EMAIL_TO=tu-correo@empresa.com

# ---- Notificaciones Webhook (Opcional: Discord, Slack, Make, n8n) ----
# NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/...

# ---- Seguridad cron Vercel ----
# Vercel envía: Authorization: Bearer <este-secreto>
CRON_SECRET=cambia-este-secreto-largo
